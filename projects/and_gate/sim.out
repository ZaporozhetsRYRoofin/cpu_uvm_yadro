:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2009.vpi";
S_0x64af14f558b0 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x64af14f55a40 .scope module, "angatetb" "angatetb" 3 1;
 .timescale 0 0;
v0x64af14f68550_0 .var "a", 0 0;
v0x64af14f68620_0 .var "b", 0 0;
v0x64af14f686f0_0 .net "out", 0 0, L_0x64af14f687f0;  1 drivers
S_0x64af14f1c490 .scope module, "dut" "andgate" 3 4, 4 1 0, S_0x64af14f55a40;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /OUTPUT 1 "out";
L_0x64af14f687f0 .functor AND 1, v0x64af14f68550_0, v0x64af14f68620_0, C4<1>, C4<1>;
v0x64af14f1c6c0_0 .net "a", 0 0, v0x64af14f68550_0;  1 drivers
v0x64af14f68370_0 .net "b", 0 0, v0x64af14f68620_0;  1 drivers
v0x64af14f68430_0 .net "out", 0 0, L_0x64af14f687f0;  alias, 1 drivers
    .scope S_0x64af14f55a40;
T_0 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x64af14f68550_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x64af14f68620_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x64af14f68550_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x64af14f68620_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x64af14f68550_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x64af14f68620_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x64af14f68550_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x64af14f68620_0, 0, 1;
    %delay 10, 0;
    %vpi_call/w 3 27 "$finish" {0 0 0};
    %end;
    .thread T_0;
    .scope S_0x64af14f55a40;
T_1 ;
    %vpi_call/w 3 30 "$monitor", "time = %0t | a = %b b = %b | out = %b", $time, v0x64af14f68550_0, v0x64af14f68620_0, v0x64af14f686f0_0 {0 0 0};
    %end;
    .thread T_1;
